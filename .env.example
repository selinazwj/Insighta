# Copy to .env and fill in values, then restart the server.
DATABASE_URL=

# Claude / Anthropic API for Insighta LLM-only prediction and recommendation
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Haiku is the cost-efficient default for structured prediction/ranking.
AI_GROWTH_CLAUDE_MODEL=claude-haiku-4-5-20251001

# Optional tuning
AI_GROWTH_LLM_MAX_TOKENS=1200
AI_GROWTH_LLM_TEMPERATURE=0.1
AI_GROWTH_LLM_BATCH_SIZE=20
AI_GROWTH_LLM_CACHE_HOURS=24
AI_GROWTH_LLM_CANDIDATE_LIMIT=60
AI_GROWTH_LLM_PREVIEW_POOL_LIMIT=60
AI_GROWTH_LLM_PREVIEW_SAMPLE_SIZE=6

# "local" avoids a second LLM call after candidate predictions are aggregated.
# Set to "llm" only when model-written publisher copy is worth the extra tokens.
AI_GROWTH_LLM_SUMMARY_MODE=local

# Optional token observability in server logs.
AI_GROWTH_LOG_TOKEN_USAGE=false

# Channel discovery controls (web-search calls are especially token-intensive).
CHANNEL_DISCOVERY_MODEL=claude-haiku-4-5-20251001
CHANNEL_DISCOVERY_MAX_TOKENS=1400
CHANNEL_DISCOVERY_MAX_SEARCHES=4
CHANNEL_DISCOVERY_CACHE_HOURS=12

# Survey authoring models.
ANTHROPIC_AI_FILL_MODEL=claude-haiku-4-5-20251001
ANTHROPIC_QUESTION_MODEL=claude-haiku-4-5-20251001

# Quality review: high_risk calls Claude only for ambiguous/suspicious responses.
# Use balanced for the previous broader behavior, or off to disable semantic calls.
QUALITY_LLM_MODE=high_risk
QUALITY_LLM_MODEL=claude-haiku-4-5-20251001
QUALITY_LLM_MAX_TOKENS=240
QUALITY_LLM_MAX_QA_PAIRS=12

# Survey result analysis sends aggregates plus bounded text samples, then caches.
SURVEY_ANALYSIS_MODEL=claude-haiku-4-5-20251001
SURVEY_ANALYSIS_MAX_TOKENS=750
SURVEY_ANALYSIS_TEXT_SAMPLES=10
SURVEY_ANALYSIS_CACHE_HOURS=6
