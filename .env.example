# Core application
DATABASE_URL=sqlite:///./survey.db
BASE_URL=https://insightaco.org

# Public SEO origin and metadata
# Keep SEO_SITE_URL on the single preferred HTTPS production origin, without a trailing slash.
SEO_SITE_URL=https://insightaco.org
SEO_SITE_NAME=Insighta
SEO_CONTACT_EMAIL=insightacom@gmail.com
SEO_DEFAULT_IMAGE=/static/screenshot-desktop.png
SEO_LANGUAGE=en-US
SEO_LOCALE=en_US
SEO_INDEX_STUDIES=true
SEO_SOCIAL_URLS=
GOOGLE_SITE_VERIFICATION=
BING_SITE_VERIFICATION=

# Payments
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# Email (Gmail SMTP or Resend)
EMAIL_PROVIDER=gmail
EMAIL_ADDRESS=
EMAIL_PASSWORD=
EMAIL_FROM=
EMAIL_REPLY_TO=
RESEND_API_KEY=
SUPPORT_ALERT_EMAIL=

# OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=

# Administrative access: generate a long random value; no default is safe for production.
ADMIN_KEY=
ADMIN_PUBLISHER_EMAIL=

# Claude / Anthropic API for autofill, matching, and AI growth features
ANTHROPIC_API_KEY=sk-ant-your-key-here
AI_GROWTH_CLAUDE_MODEL=claude-sonnet-4-5
ANTHROPIC_AI_FILL_MODEL=
ALLOW_EXPENSIVE_ANTHROPIC_MODELS=false

# Optional AI tuning
AI_GROWTH_LLM_MAX_TOKENS=1400
AI_GROWTH_LLM_TEMPERATURE=0.1
AI_GROWTH_LLM_BATCH_SIZE=25
AI_GROWTH_LLM_CACHE_HOURS=6
AI_GROWTH_LLM_CANDIDATE_LIMIT=120

# Participant follow-up worker
SURVEY_START_FOLLOWUP_DELAY_MINUTES=5
SURVEY_START_FOLLOWUP_POLL_SECONDS=60
