# Copy to .env and fill in values, then restart the server.
DATABASE_URL=

# Claude / Anthropic API for Insighta LLM-only prediction and recommendation
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Pick your Claude model here. Change this if your Anthropic account uses a different model alias.
AI_GROWTH_CLAUDE_MODEL=claude-sonnet-4-5

# Optional tuning
AI_GROWTH_LLM_MAX_TOKENS=1400
AI_GROWTH_LLM_TEMPERATURE=0.1
AI_GROWTH_LLM_BATCH_SIZE=25
AI_GROWTH_LLM_CACHE_HOURS=6
AI_GROWTH_LLM_CANDIDATE_LIMIT=120
